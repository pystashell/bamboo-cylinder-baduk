{
  "name": "bamboo-baduk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run dev:online",
    "dev:ui": "vite",
    "dev:online": "npm run build && wrangler dev --port 8787",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test",
    "test:release": "node --test scripts/release.test.mjs",
    "test:live": "node scripts/live-room-smoke.mjs",
    "deploy": "npm run build && wrangler deploy",
    "release:version": "node scripts/release.mjs version",
    "release:plan": "node scripts/release.mjs plan",
    "release:check": "node scripts/release.mjs check",
    "release:publish": "node scripts/release.mjs publish",
    "release:list": "node scripts/release.mjs list",
    "release:rollback": "node scripts/release.mjs rollback"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "pako": "^2.2.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
